{
  "env": {
    "vars": {
      "MOLTBOOK_API_KEY": "",
      "OPENAI_API_KEY": "",
      "SOKOSUMI_API_KEY": "",
      "OLLAMA_API_KEY": "ollama-local"
    }
  },
  "logging": {
    "level": "info",
    "consoleLevel": "info",
    "consoleStyle": "pretty",
    "redactSensitive": "tools",
    "redactPatterns": [
      "\\bMOLTBOOK_API_KEY\\s*[=:]\\s*([^\\s]+)",
      "\\bOPENAI_API_KEY\\s*[=:]\\s*([^\\s]+)",
      "\\bSOKOSUMI_API_KEY\\s*[=:]\\s*([^\\s]+)",
      "\\bOLLAMA_API_KEY\\s*[=:]\\s*([^\\s]+)",
      "\\bOPENCLAW_GATEWAY_TOKEN\\s*[=:]\\s*([^\\s]+)"
    ]
  },
  "agents": {
    "list": [
      {
        "id": "logan",
        "default": true,
        "name": "Logan",
        "workspace": "./workspace",
        "model": {
          "primary": "ollama/gemma4:e2b",
          "fallbacks": ["ollama/gemma4:e4b", "ollama/llama3.2:1b"]
        },
        "memorySearch": {
          "enabled": true,
          "extraPaths": ["./knowledge"],
          "provider": "openai",
          "model": "text-embedding-3-small",
          "query": {
            "hybrid": {
              "enabled": true,
              "vectorWeight": 0.7,
              "textWeight": 0.3,
              "candidateMultiplier": 4
            }
          },
          "cache": {
            "enabled": true,
            "maxEntries": 50000
          }
        },
        "heartbeat": {
          "every": "1h"
        },
        "sandbox": {
          "mode": "all",
          "workspaceAccess": "rw",
          "scope": "agent",
          "docker": {
            "image": "openclaw-sandbox:bookworm-slim",
            "readOnlyRoot": true,
            "tmpfs": ["/tmp", "/var/tmp", "/run"],
            "network": "oc-sandbox-net",
            "capDrop": ["ALL"],
            "pidsLimit": 256,
            "memory": "512m",
            "cpus": 1,
            "seccompProfile": "./security/seccomp-sandbox.json",
            "dns": ["172.30.0.10"],
            "extraHosts": ["proxy:172.30.0.10"],
            "user": "sandboxuser"
          }
        },
        "tools": {
          "profile": "minimal",
          "alsoAllow": [
            "exec",
            "read",
            "write",
            "edit",
            "memory_search",
            "memory_get",
            "sokosumi_list_agents",
            "sokosumi_get_agent",
            "sokosumi_get_input_schema",
            "sokosumi_list_jobs"
          ],
          "deny": [
            "browser",
            "canvas",
            "web_search",
            "web_fetch",
            "process",
            "subagents",
            "sessions_spawn",
            "sokosumi_create_job"
          ],
          "exec": {
            "host": "sandbox",
            "security": "allowlist",
            "safeBins": ["curl"],
            "timeoutSec": 120
          }
        }
      }
    ],
    "defaults": {
      "maxConcurrent": 4,
      "subagents": {
        "maxConcurrent": 8
      }
    }
  },
  "tools": {
    "sokosumi": {
      "apiEndpoint": "https://api.sokosumi.com/v1"
    }
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto"
  },
  "gateway": {
    "mode": "local",
    "auth": {
      "mode": "token"
    }
  },
  "messages": {
    "ackReactionScope": "group-mentions"
  },
  "meta": {
    "lastTouchedVersion": "2026.7.2",
    "lastTouchedAt": "2026-07-13T16:30:00.000Z"
  }
}
